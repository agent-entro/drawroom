{
  "name": "@drawroom/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/index.js",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "db:migrate": "node --import tsx/esm src/db/migrate.ts"
  },
  "dependencies": {
    "@drawroom/shared": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "ioredis": "^5.4.0",
    "node-cron": "^3.0.3",
    "postgres": "^3.4.4",
    "human-id": "^4.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
